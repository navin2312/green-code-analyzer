@@ -1,5 +1,18 @@
 # Analytics reporting module
+import pandas as pd
+
+def compute_revenue(df):
+    total = 0
+    for idx, row in df.iterrows():
+        total += row['qty'] * row['unit_price']
+    return total
+
+def build_report_text(records):
+    text = ''
+    for rec in records:
+        text += rec['name'] + ': ' + str(rec['value']) + '\n'
+    return text
+
+def fib(n):
+    if n <= 1: return n
+    return fib(n-1) + fib(n-2)
